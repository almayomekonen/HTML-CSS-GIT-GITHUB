# ===========================================================
#  Dockerfile - דף ההוראות לאפיית ה-Image של האפליקציה שלנו
#  כל שורה כאן היא "צעד" שבונה שכבה (layer) ב-Image
# ===========================================================

# שלב 1: מאיזה בסיס מתחילים?
# במקום להתקין Node ידנית, לוקחים Image מוכן שכבר מכיל Node 20.
# "alpine" = גרסה זעירה של לינוקס -> Image קטן ומהיר.
FROM node:20-alpine

# שלב 2: באיזו תיקייה בתוך ה-container נעבוד?
# כל הפקודות הבאות ירוצו מתוך /app (התיקייה תיווצר אוטומטית).
WORKDIR /app

# שלב 3: מעתיקים קודם רק את קבצי ה-dependencies.
# למה רק אותם ולא הכל? בגלל "caching":
# כל עוד package.json לא משתנה, Docker ידלג על שלב ההתקנה
# הבא ב-build הבא -> בנייה הרבה יותר מהירה.
COPY package*.json ./

# שלב 4: מתקינים את החבילות (express, mongoose וכו') בתוך ה-Image.
RUN npm install

# שלב 5: עכשיו מעתיקים את כל שאר קוד האפליקציה לתוך ה-container.
COPY . .

# שלב 6: מצהירים שהאפליקציה מאזינה על פורט 3000.
# זו "תיעוד" בלבד - המיפוי בפועל נעשה עם -p בזמן הריצה.
EXPOSE 3000

# שלב 7: הפקודה שתרוץ כשה-container עולה.
# שים לב: מריצים "node app.js" ולא "nodemon" -
# nodemon נועד לפיתוח (מאזין לשינויים), ב-container לא צריך אותו.
CMD ["node", "app.js"]
