# ===========================================================
#  .dockerignore - מה לא להעתיק לתוך ה-Image
#  בדיוק כמו .gitignore, רק עבור Docker
# ===========================================================

# 1. node_modules - לא מעתיקים! מתקינים מחדש בתוך ה-container
#    (RUN npm install). העתקה מהמחשב עלולה לשבור דברים בלינוקס.
node_modules

# 2. .env - הסודות שלנו (סיסמת מסד הנתונים)!
#    הם לא נכנסים ל-Image. נעביר אותם בזמן ריצה עם --env-file.
.env

# 3. דברים שלא רלוונטיים ל-container
.git
.gitignore
Dockerfile
.dockerignore
*.md
requests.http
